generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      String   @default("user") // "user" or "owner"
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings     Booking[]
  reviews      Review[]
  chatsSent    ChatMessage[] @relation("ChatSender")
  chatsReceived ChatMessage[] @relation("ChatReceiver")
  surveys      Survey[]
  ownedKos     Kos[]
}

model Kos {
  id          String   @id @default(cuid())
  name        String
  description String
  address     String
  city        String
  district    String
  latitude    Float?
  longitude   Float?
  ownerId     String
  imageUrl    String?
  priceFrom   Int      // monthly price in IDR
  priceTo     Int      // monthly price in IDR
  totalRooms  Int
  availableRooms Int
  rules       String?  // JSON string for rules
  roomTypes   String?  // JSON string for room types
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User      @relation(fields: [ownerId], references: [id])
  facilities KosFacility[]
  reviews   Review[]
  rooms     Room[]
  promos    Promo[]
  bookings  Booking[]
  surveys   Survey[]
}

model Room {
  id         String   @id @default(cuid())
  kosId      String
  name       String
  type       String   // "Single", "Double", "Suite", etc.
  price      Int      // monthly price
  size       String?  // room size
  isAvailable Boolean @default(true)
  imageUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  kos      Kos      @relation(fields: [kosId], references: [id])
  bookings Booking[]
}

model Facility {
  id   String @id @default(cuid())
  name String @unique
  icon String? // icon name

  kos KosFacility[]
}

model KosFacility {
  kosId       String
  facilityId  String

  kos      Kos      @relation(fields: [kosId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@id([kosId, facilityId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  kosId     String
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  kos  Kos  @relation(fields: [kosId], references: [id])
}

model Booking {
  id          String   @id @default(cuid())
  userId      String
  kosId       String
  roomId      String
  checkInDate String
  duration    Int      // months
  totalPrice  Int
  status      String   @default("pending") // pending, paid, confirmed, cancelled, completed
  paymentMethod String? // "ewallet", "transfer"
  paymentProof  String? // proof of payment image URL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id])
  kos  Kos   @relation(fields: [kosId], references: [id])
  room Room  @relation(fields: [roomId], references: [id])
}

model Survey {
  id          String   @id @default(cuid())
  userId      String
  kosId       String
  scheduledDate String
  scheduledTime String
  status      String   @default("pending") // pending, confirmed, completed, cancelled
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  kos  Kos  @relation(fields: [kosId], references: [id])
}

model Promo {
  id          String   @id @default(cuid())
  kosId       String
  title       String
  description String
  imageUrl    String?
  startDate   String
  endDate     String
  discount    Int?     // percentage
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kos Kos @relation(fields: [kosId], references: [id])
}

model ChatMessage {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  kosId      String?
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("ChatSender", fields: [senderId], references: [id])
  receiver User @relation("ChatReceiver", fields: [receiverId], references: [id])
}
